# Neon PostgreSQL (injectées automatiquement par Vercel via intégration Neon)
DATABASE_URL=

# Stack Auth — créer un projet sur https://app.stack-auth.com
# Dans le dashboard Stack Auth : Settings > Domains, ajouter https://shadow-fitness-system.vercel.app
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Web Push VAPID (générer avec: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@shadow-fitness.app

# Strava OAuth (configurer après premier déploiement)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://shadow-fitness-system.vercel.app/api/strava/callback
